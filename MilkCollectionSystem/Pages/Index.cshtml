@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .hero-text {
        position: absolute;
        top: 30%;
        left: 10%;
        color: white;
        text-shadow: 2px 2px 10px black;
    }

    .hero-title {
        font-size: 55px;
        font-weight: bold;
    }

    .hero-sub {
        font-size: 22px;
    }

    .carousel-item img {
        height: 80vh;
        object-fit: cover;
    }

    .overlay-btn {
        margin-top: 20px;
    }

    .stats-card {
        border-radius: 15px;
        padding: 20px;
        color: white;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .blue {
        background: linear-gradient(135deg, #4e73df, #224abe);
    }

    .green {
        background: linear-gradient(135deg, #1cc88a, #13855c);
    }

    .yellow {
        background: linear-gradient(135deg, #f6c23e, #dda20a);
    }
</style>

<!-- CAROUSEL -->
<div id="milkCarousel" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-inner">

        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1596733430284-f7437764b1a9"
                 class="d-block w-100">

            <div class="hero-text">
                <div class="hero-title">Milk Collection System</div>
                <div class="hero-sub">Modern dairy management for farmers & factories</div>

                <div class="overlay-btn">
                    <a asp-page="/Identity/Account/Login" class="btn btn-light btn-lg">
                        Get Started
                    </a>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1581091012184-5c3c2f8a0c7b"
                 class="d-block w-100">
        </div>

        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1500595046743-cd271d694d30"
                 class="d-block w-100">
        </div>

    </div>

</div>

<!-- STATS SECTION -->
<div class="container mt-5">

    <div class="row g-4">

        <div class="col-md-4">
            <div class="stats-card blue">
                <h3>🐄 Farmers</h3>
                <h2>@Model.TotalFarmers</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stats-card green">
                <h3>🥛 Total Milk</h3>
                <h2>@Model.TotalLitres L</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="stats-card yellow">
                <h3>📊 Deliveries</h3>
                <h2>@Model.TotalDeliveries</h2>
            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>