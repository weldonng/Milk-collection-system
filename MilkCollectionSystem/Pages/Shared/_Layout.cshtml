<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Milk Collection System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>

<body>

    <!-- TOP NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-success">
        <div class="container-fluid">

            <a class="navbar-brand" asp-page="/Index">
                🥛 Milk Collection System
            </a>

            <div class="ms-auto">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-white me-3">
                        👤 @User.Identity.Name
                    </span>

                    <form asp-area="Identity"
                          asp-page="/Account/Logout"
                          method="post"
                          class="d-inline">

                        <button class="btn btn-light btn-sm">
                            Logout
                        </button>

                    </form>
                }
                else
                {
                    <a class="btn btn-outline-light me-2"
                       asp-area="Identity"
                       asp-page="/Account/Login">
                        Login
                    </a>

                    <a class="btn btn-light"
                       asp-area="Identity"
                       asp-page="/Account/Register">
                        Register
                    </a>
                }

            </div>

        </div>
    </nav>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-dark text-white p-3" style="width:220px; min-height:100vh;">

            <h4 class="text-center mb-4">
                🥛 Milk System
            </h4>

            <ul class="nav flex-column">

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-page="/Index">
                        🏠 Home
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-page="/Dashboard">
                        📊 Dashboard
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-page="/MilkCollection">
                        🥛 Milk Collection
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-page="/MilkRecords">
                        📄 Milk Records
                    </a>
                </li>

                <li class="nav-item mb-2">
                    <a class="nav-link text-white" asp-page="/Farmer">
                        👨‍🌾 Farmers
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item mb-2">
                        <a class="nav-link text-white" asp-page="/AddFarmer">
                            ➕ Add Farmer
                        </a>
                    </li>
                }

            </ul>

        </div>

        <!-- MAIN CONTENT -->
        <div class="flex-grow-1 p-4">

            @RenderBody()

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>